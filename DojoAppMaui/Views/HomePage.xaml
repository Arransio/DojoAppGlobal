<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DojoAppMaui.Views.HomePage">

    <Grid RowDefinitions="*,Auto">

     
        <CollectionView x:Name="ProductsCollectionView" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5">
                        <VerticalStackLayout>

                            <Label Text="{Binding Name}" FontSize="18" />
                            <Label Text="{Binding Price}" FontSize="14" />

                            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Sizes}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Button 
											x:Name="SizeButton"
                                            Text="{Binding .}" 
                                            Padding="5"
                                            Margin="2"
                                            Clicked="OnSizeClicked"/>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>

                            <Button 
                                Text="Añadir al carrito"
                                Margin="5"
                                Clicked="OnAddToCartClicked"/>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="1" BackgroundColor="Black" Padding="10" ColumnDefinitions="*,Auto">

            <Label 
                x:Name="CartSummaryLabel"
                Text="0 items - 0€"
                TextColor="White"
                VerticalOptions="Center"/>

            <Button 
                Text="🛒"
                Grid.Column="1"
                Clicked="OnCartClicked"/>

        </Grid>

    </Grid>

</ContentPage>