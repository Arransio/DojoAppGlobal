<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:controls="clr-namespace:DojoAppMaui.Controls"
			 x:Class="DojoAppMaui.Views.HomePage"
			 NavigationPage.HasNavigationBar="False"
			 BackgroundColor="{StaticResource ObsidianBg}">

	<Grid RowDefinitions="Auto,*,Auto">

		<!-- Banner de usuario logueado (ancho completo) -->
		<Border Grid.Row="0"
				BackgroundColor="{StaticResource GlassFill}"
				Stroke="{StaticResource Hairline}" StrokeThickness="1"
				StrokeShape="RoundRectangle 0,0,20,20" Padding="20,16">
			<HorizontalStackLayout Spacing="14" HorizontalOptions="Start" VerticalOptions="Center">
				<!-- Avatar circular: color del cinturón + franjas por grado -->
				<Border x:Name="AvatarBorder" WidthRequest="48" HeightRequest="48" Padding="0"
						BackgroundColor="{StaticResource SurfaceHigh}"
						Stroke="{StaticResource Hairline}" StrokeThickness="1"
						StrokeShape="RoundRectangle 24"
						VerticalOptions="Center">
					<VerticalStackLayout x:Name="AvatarStripes" Spacing="4"
						   VerticalOptions="Center" HorizontalOptions="Fill"/>
				</Border>
				<VerticalStackLayout Spacing="1" VerticalOptions="Center">
					<Label Text="SESIÓN INICIADA" Style="{StaticResource ChipLabel}" FontSize="10"/>
					<Label x:Name="UsernameLabel" Text="—"
						   FontFamily="Sora" FontAttributes="Bold" FontSize="20"
						   TextColor="{StaticResource TextPrimary}"
						   LineBreakMode="TailTruncation" MaxLines="1"/>
				</VerticalStackLayout>
			</HorizontalStackLayout>
		</Border>

		<!-- Contenido principal con Kanji de fondo -->
		<Grid Grid.Row="1">

			<!-- Kanji 柔 ("ju": flexibilidad/suavidad, principio del Jiu-Jitsu) como marca de agua -->
			<Label Text="柔"
				   FontSize="360"
				   FontAttributes="Bold"
				   TextColor="{StaticResource AccentSalmon}"
				   Opacity="0.10"
				   HorizontalOptions="Center" VerticalOptions="Center"
				   HorizontalTextAlignment="Center"
				   InputTransparent="True"/>

			<ScrollView>
				<VerticalStackLayout Padding="20,18,20,24" Spacing="18">

					<!-- Cabecera -->
					<VerticalStackLayout Spacing="2">
						<Label Text="CLASES" Style="{StaticResource ChipLabel}"/>
						<Label Text="Horario" Style="{StaticResource DisplayTitle}"/>
					</VerticalStackLayout>

					<!-- Placeholder: calendario de clases -->
					<Border Style="{StaticResource GlassCard}" HeightRequest="300">
						<VerticalStackLayout Spacing="10"
											 HorizontalOptions="Center" VerticalOptions="Center">
							<Label Text="&#x1F4C5;" FontSize="52" HorizontalOptions="Center"
								   TextColor="{StaticResource SurfaceHighest}"/>
							<Label Text="Calendario de clases"
								   FontFamily="Sora" FontAttributes="Bold" FontSize="16"
								   TextColor="{StaticResource TextPrimary}"
								   HorizontalOptions="Center"/>
							<Label Text="Próximamente" Style="{StaticResource MutedLabel}"
								   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
						</VerticalStackLayout>
					</Border>

					<!-- Placeholder: tips / frases de Jiu-Jitsu -->
					<Border Style="{StaticResource GlassCard}">
						<VerticalStackLayout Spacing="6">
							<Label Text="TIP DEL DÍA" Style="{StaticResource ChipLabel}"
								   TextColor="{StaticResource AccentSalmon}"/>
							<Label Text="Aquí aparecerán frases importantes del Jiu-Jitsu a modo de recordatorios."
								   Style="{StaticResource MutedLabel}"/>
						</VerticalStackLayout>
					</Border>

				</VerticalStackLayout>
			</ScrollView>

		</Grid>

		<!-- Banner de navegación global -->
		<controls:BottomNavBar x:Name="NavBar" Grid.Row="2" ActiveTab="Inicio"/>

	</Grid>

</ContentPage>
