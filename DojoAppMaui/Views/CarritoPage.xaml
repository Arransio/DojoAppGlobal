<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DojoAppMaui.Controls"
             x:Class="DojoAppMaui.Views.CarritoPage"
             Title="Carrito"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource ObsidianBg}">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Cabecera -->
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,4" Spacing="2">
            <Label Text="REVISA TU PEDIDO" Style="{StaticResource ChipLabel}"/>
            <Label Text="Carrito" Style="{StaticResource DisplayTitle}"/>
        </VerticalStackLayout>

        <CollectionView x:Name="CartCollection" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource GlassCard}" Margin="16,6">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="{Binding Size, StringFormat='Talla: {0}'}" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                                <Label Text="{Binding PrimaryColorName, StringFormat='Color principal: {0}'}" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                                <Label Text="{Binding SecondaryColorName, StringFormat='Color secundario: {0}'}" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                                <Label Text="{Binding UnitPrice, StringFormat='{}{0:F2} € / ud.'}" FontSize="12" TextColor="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            </VerticalStackLayout>

                            <Button Text="🗑"
                                    Grid.Column="1"
                                    Clicked="OnRemoveClicked"
                                    BackgroundColor="{StaticResource SurfaceHigh}"
                                    TextColor="{StaticResource ErrorRed}"
                                    CornerRadius="10"
                                    Padding="12"
                                    WidthRequest="48"
                                    HeightRequest="48"
                                    VerticalOptions="Start"/>

                            <!-- Cantidad (stepper) + total de la línea -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="10" VerticalOptions="Center">
                                <Button Text="−"
                                        Clicked="OnDecrementClicked"
                                        BackgroundColor="{StaticResource SurfaceHigh}"
                                        TextColor="{StaticResource TextPrimary}"
                                        CornerRadius="10" Padding="0"
                                        WidthRequest="40" HeightRequest="40"
                                        FontSize="18" FontAttributes="Bold"/>
                                <Label Text="{Binding Quantity}"
                                       FontFamily="Sora" FontAttributes="Bold" FontSize="16"
                                       TextColor="{StaticResource TextPrimary}"
                                       WidthRequest="28" HorizontalTextAlignment="Center"
                                       VerticalOptions="Center"/>
                                <Button Text="+"
                                        Clicked="OnIncrementClicked"
                                        BackgroundColor="{StaticResource SurfaceHigh}"
                                        TextColor="{StaticResource TextPrimary}"
                                        CornerRadius="10" Padding="0"
                                        WidthRequest="40" HeightRequest="40"
                                        FontSize="18" FontAttributes="Bold"/>
                            </HorizontalStackLayout>

                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding TotalPrice, StringFormat='{}{0:F2} €'}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource AccentSalmon}"
                                   VerticalOptions="Center" HorizontalOptions="End"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Estado vacío: sin artículos no hay lista, hay una invitación al catálogo -->
        <VerticalStackLayout x:Name="EmptyCartView" Grid.Row="1" IsVisible="False"
                             Spacing="8" Padding="32"
                             VerticalOptions="Center" HorizontalOptions="Center">
            <Label Text="🛒" FontSize="42" HorizontalOptions="Center"/>
            <Label Text="Tu carrito está vacío"
                   FontFamily="Sora" FontAttributes="Bold" FontSize="17"
                   TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center"/>
            <Label Text="Añade productos desde el catálogo de pedidos."
                   Style="{StaticResource MutedLabel}" FontSize="13"
                   HorizontalTextAlignment="Center" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Resumen + confirmar -->
        <Border Grid.Row="2" BackgroundColor="{StaticResource SurfaceLowest}" Stroke="{StaticResource Hairline}" StrokeThickness="1" StrokeShape="RoundRectangle 16,16,0,0" Padding="20,16">
            <VerticalStackLayout Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="PRECIO TOTAL" Style="{StaticResource ChipLabel}" VerticalOptions="Center"/>
                    <Label x:Name="TotalLabel"
                           Grid.Column="1"
                           Style="{StaticResource PriceLabel}"
                           FontSize="28"
                           TextColor="{StaticResource AccentSalmon}"
                           HorizontalOptions="End"/>
                </Grid>

                <Button x:Name="ConfirmOrderButton"
                        Text="CONFIRMAR PEDIDO"
                        Clicked="OnConfirmOrderClicked"
                        CharacterSpacing="1.5" />

                <Label Text="🔒  Pago seguro"
                       Style="{StaticResource MutedLabel}"
                       FontSize="12"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <!-- Banner de navegación global -->
        <controls:BottomNavBar x:Name="NavBar" Grid.Row="3" ActiveTab="Carrito"/>

    </Grid>

</ContentPage>
