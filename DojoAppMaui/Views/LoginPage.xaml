<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="DojoAppMaui.Views.LoginPage">

    <ScrollView>
        <VerticalStackLayout 
            Padding="30"
            Spacing="15"
            VerticalOptions="Center">

            <!-- Logo -->
            <Image 
                Source="icono_image.png"
                HeightRequest="120"
                HorizontalOptions="Center"/>

            <!-- Credenciales del utuario -->
			<Entry 
                Placeholder="Usuario"
                Text="{Binding Username}" />

		    <Entry 
                Placeholder="Contraseña"
                IsPassword="True"
                Text="{Binding Password}" />

			<Button 
				Text="Iniciar sesión"
				Command="{Binding LoginCommand}" />

			<!-- Botón de registro -->
			<Button 
				Text="{Binding RegisterButtonText}"
				Command="{Binding RegisterCommand}"
				IsEnabled="{Binding IsRegisterButtonEnabled}"
				BackgroundColor="Transparent"
				TextColor="Blue"
				FontSize="14"/>

			<!-- botonsito de recordar usuario -->
            <HorizontalStackLayout>
                <CheckBox />
                <Label Text="Recordar usuario"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Olvidaste contraseña¿?¿? -->
            <Label 
                Text="¿Olvidaste tu contraseña?"
                TextColor="Blue">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>