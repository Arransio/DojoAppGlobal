<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DojoAppMaui.Controls"
             x:Class="DojoAppMaui.Views.UsuarioPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource ObsidianBg}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Cabecera -->
        <VerticalStackLayout Grid.Row="0" Padding="20,18,20,8" Spacing="2">
            <Label Text="PERFIL" Style="{StaticResource ChipLabel}"/>
            <Label Text="Usuario" Style="{StaticResource DisplayTitle}"/>
        </VerticalStackLayout>

        <!-- Formulario -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="22">

                <!-- Foto de perfil -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Border WidthRequest="112" HeightRequest="112" Padding="0"
                            BackgroundColor="{StaticResource SurfaceHigh}"
                            Stroke="{StaticResource Hairline}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 56"
                            HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                        </Border.GestureRecognizers>
                        <Grid>
                            <!-- Icono por defecto (si no hay foto) -->
                            <Path x:Name="AvatarPlaceholder" HeightRequest="56" WidthRequest="56"
                                  Aspect="Uniform" Fill="{StaticResource TextSecondary}"
                                  HorizontalOptions="Center" VerticalOptions="Center"
                                  Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                            <!-- Foto elegida (si existe) -->
                            <Image x:Name="AvatarImage" Aspect="AspectFill" IsVisible="False"/>
                        </Grid>
                    </Border>
                    <Label x:Name="AvatarHintLabel" Text="Toca para añadir foto"
                           FontSize="11" HorizontalOptions="Center"
                           TextColor="{StaticResource TextSecondary}"/>
                </VerticalStackLayout>

                <!-- Nombre y apellidos -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="NOMBRE Y APELLIDOS" Style="{StaticResource ChipLabel}"/>
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry x:Name="NombreEntry" Placeholder="Tu nombre completo"
                               TextChanged="OnNombreChanged"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Cinturón -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="CINTURÓN" Style="{StaticResource ChipLabel}"/>
                    <Border Style="{StaticResource GlassCard}">
                        <HorizontalStackLayout x:Name="CinturonRow" Spacing="12" HorizontalOptions="Center">

                            <VerticalStackLayout x:Name="BeltItemBlanco" Spacing="6" HorizontalOptions="Center">
                                <Border x:Name="BeltBlanco" WidthRequest="46" HeightRequest="46" Padding="0"
                                        BackgroundColor="#FFFFFF"
                                        Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 23">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeltTapped" CommandParameter="Blanco"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="Blanco" FontSize="10" HorizontalOptions="Center"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout x:Name="BeltItemAzul" Spacing="6" HorizontalOptions="Center">
                                <Border x:Name="BeltAzul" WidthRequest="46" HeightRequest="46" Padding="0"
                                        BackgroundColor="#1E66F5"
                                        Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 23">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeltTapped" CommandParameter="Azul"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="Azul" FontSize="10" HorizontalOptions="Center"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout x:Name="BeltItemMorado" Spacing="6" HorizontalOptions="Center">
                                <Border x:Name="BeltMorado" WidthRequest="46" HeightRequest="46" Padding="0"
                                        BackgroundColor="#7C3AED"
                                        Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 23">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeltTapped" CommandParameter="Morado"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="Morado" FontSize="10" HorizontalOptions="Center"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout x:Name="BeltItemMarron" Spacing="6" HorizontalOptions="Center">
                                <Border x:Name="BeltMarron" WidthRequest="46" HeightRequest="46" Padding="0"
                                        BackgroundColor="#8B5A2B"
                                        Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 23">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeltTapped" CommandParameter="Marron"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="Marrón" FontSize="10" HorizontalOptions="Center"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout x:Name="BeltItemNegro" Spacing="6" HorizontalOptions="Center">
                                <Border x:Name="BeltNegro" WidthRequest="46" HeightRequest="46" Padding="0"
                                        BackgroundColor="#000000"
                                        Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 23">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeltTapped" CommandParameter="Negro"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="Negro" FontSize="10" HorizontalOptions="Center"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>

                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Grados -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="GRADOS" Style="{StaticResource ChipLabel}"/>
                    <Border Style="{StaticResource GlassCard}">
                        <HorizontalStackLayout x:Name="GradoRow" Spacing="10" HorizontalOptions="Center">

                            <Border x:Name="Grado0" WidthRequest="52" HeightRequest="48" Padding="0"
                                    BackgroundColor="{StaticResource SurfaceLowest}"
                                    Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGradoTapped" CommandParameter="0"/>
                                </Border.GestureRecognizers>
                                <Label x:Name="Grado0Label" Text="0" FontFamily="Sora" FontAttributes="Bold"
                                       FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </Border>

                            <Border x:Name="Grado1" WidthRequest="52" HeightRequest="48" Padding="0"
                                    BackgroundColor="{StaticResource SurfaceLowest}"
                                    Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGradoTapped" CommandParameter="1"/>
                                </Border.GestureRecognizers>
                                <Label x:Name="Grado1Label" Text="1" FontFamily="Sora" FontAttributes="Bold"
                                       FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </Border>

                            <Border x:Name="Grado2" WidthRequest="52" HeightRequest="48" Padding="0"
                                    BackgroundColor="{StaticResource SurfaceLowest}"
                                    Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGradoTapped" CommandParameter="2"/>
                                </Border.GestureRecognizers>
                                <Label x:Name="Grado2Label" Text="2" FontFamily="Sora" FontAttributes="Bold"
                                       FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </Border>

                            <Border x:Name="Grado3" WidthRequest="52" HeightRequest="48" Padding="0"
                                    BackgroundColor="{StaticResource SurfaceLowest}"
                                    Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGradoTapped" CommandParameter="3"/>
                                </Border.GestureRecognizers>
                                <Label x:Name="Grado3Label" Text="3" FontFamily="Sora" FontAttributes="Bold"
                                       FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </Border>

                            <Border x:Name="Grado4" WidthRequest="52" HeightRequest="48" Padding="0"
                                    BackgroundColor="{StaticResource SurfaceLowest}"
                                    Stroke="{StaticResource Hairline}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGradoTapped" CommandParameter="4"/>
                                </Border.GestureRecognizers>
                                <Label x:Name="Grado4Label" Text="4" FontFamily="Sora" FontAttributes="Bold"
                                       FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}"/>
                            </Border>

                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Guardar (se oculta tras guardar, reaparece al cambiar algo) -->
                <Button x:Name="GuardarButton" Text="Guardar" IsVisible="False"
                        Clicked="OnGuardarClicked"/>

                <!-- Historial de pedidos (placeholder) -->
                <Button Text="Historial de pedidos" Style="{StaticResource GhostButton}"
                        Clicked="OnHistorialClicked"/>

                <!-- Cerrar sesión: borra la sesión pero conserva el perfil local -->
                <Button Text="Cerrar sesión" Style="{StaticResource GhostButton}"
                        TextColor="{StaticResource AccentRed}"
                        BorderColor="{StaticResource AccentRed}"
                        Clicked="OnCerrarSesionClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Banner de navegación global -->
        <controls:BottomNavBar x:Name="NavBar" Grid.Row="2" ActiveTab="Usuario"/>

    </Grid>

</ContentPage>
