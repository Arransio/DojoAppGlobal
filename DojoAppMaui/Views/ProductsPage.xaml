<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="DojoAppMaui.Views.ProductsPage"
    BackgroundColor="{StaticResource ObsidianBg}">

    <Grid RowDefinitions="*,Auto">

        <CollectionView ItemsSource="{Binding Products}" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Style="{StaticResource GlassCard}" Margin="16,6">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="{Binding Price, StringFormat='€{0:F2}'}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource AccentSalmon}"/>

                            <Label Text="TALLA" Style="{StaticResource ChipLabel}" Margin="0,4,0,0"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker
                                    Title="Selecciona talla"
                                    ItemsSource="{Binding ProductVariants}"
                                    ItemDisplayBinding="{Binding Size}"
                                    SelectedItem="{Binding SelectedVariant}" />
                            </Border>

                            <CollectionView ItemsSource="{Binding SelectedVariant.Colors}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Color="{StaticResource AccentRed}" />
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Button Text="−" WidthRequest="48" HeightRequest="44" CornerRadius="8" BackgroundColor="{StaticResource SurfaceHigh}" TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="{Binding Quantity}" VerticalOptions="Center" FontSize="16" FontAttributes="Bold" WidthRequest="40" HorizontalTextAlignment="Center"/>
                                <Button Text="+" WidthRequest="48" HeightRequest="44" CornerRadius="8" BackgroundColor="{StaticResource SurfaceHigh}" TextColor="{StaticResource TextPrimary}"/>
                            </HorizontalStackLayout>

                            <Label Text="{Binding Total, StringFormat='Total: €{0:F2}'}" FontSize="15" TextColor="{StaticResource TextSecondary}"/>

                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="1" BackgroundColor="{StaticResource SurfaceLowest}" Stroke="{StaticResource Hairline}" StrokeThickness="1" StrokeShape="RoundRectangle 16,16,0,0" Padding="20,16">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="TOTAL" Style="{StaticResource ChipLabel}" VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="{Binding Total, StringFormat='€{0:F2}'}"
                       Style="{StaticResource PriceLabel}"
                       FontSize="26"
                       TextColor="{StaticResource AccentSalmon}"
                       HorizontalOptions="End"/>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
