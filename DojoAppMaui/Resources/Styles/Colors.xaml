<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- ======================================================== -->
    <!--  OBSIDIAN REDUX  —  paleta de la app (modo oscuro)        -->
    <!--  Lujo tecnológico: negro absorbente + energía roja        -->
    <!-- ======================================================== -->

    <!-- Superficies (de la más profunda a la más elevada) -->
    <Color x:Key="ObsidianBg">#131313</Color>
    <Color x:Key="SurfaceLowest">#0e0e0e</Color>
    <Color x:Key="SurfaceLow">#1c1b1b</Color>
    <Color x:Key="SurfaceContainer">#20201f</Color>
    <Color x:Key="SurfaceHigh">#2a2a2a</Color>
    <Color x:Key="SurfaceHighest">#353535</Color>
    <Color x:Key="SurfaceBright">#393939</Color>

    <!-- Texto -->
    <Color x:Key="TextPrimary">#e5e2e1</Color>
    <Color x:Key="TextSecondary">#c6c6c6</Color>
    <Color x:Key="TextWarmVariant">#e4beba</Color>

    <!-- Acento rojo (la "energía visceral") -->
    <Color x:Key="AccentRed">#d32f2f</Color>
    <Color x:Key="AccentRedHover">#ba1a20</Color>
    <Color x:Key="AccentSalmon">#ffb3ac</Color>
    <Color x:Key="OnAccent">#fff2f0</Color>
    <Color x:Key="ErrorRed">#ffb4ab</Color>
    <Color x:Key="SuccessGreen">#9fd8a4</Color>  <!-- estados "pagado"/OK, tono pastel acorde al ErrorRed -->


    <!-- Contornos / divisores -->
    <Color x:Key="OutlineWarm">#ab8985</Color>
    <Color x:Key="OutlineDim">#5b403d</Color>
    <Color x:Key="Hairline">#1AFFFFFF</Color>   <!-- blanco 10% -->
    <Color x:Key="HairlineSoft">#0DFFFFFF</Color> <!-- blanco 5%  -->
    <Color x:Key="GlassFill">#99131313</Color>   <!-- panel translúcido -->

    <!-- Compatibilidad: claves MAUI originales reapuntadas al nuevo sistema -->
    <Color x:Key="Primary">#d32f2f</Color>
    <Color x:Key="PrimaryDark">#d32f2f</Color>
    <Color x:Key="PrimaryDarkText">#fff2f0</Color>
    <Color x:Key="Secondary">#c6c6c6</Color>
    <Color x:Key="SecondaryDarkText">#ffb3ac</Color>
    <Color x:Key="Tertiary">#ffb3ac</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#131313</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- Obsidian Redux brushes -->
    <SolidColorBrush x:Key="ObsidianBgBrush" Color="{StaticResource ObsidianBg}"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainer}"/>
    <SolidColorBrush x:Key="GlassFillBrush" Color="{StaticResource GlassFill}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentSalmonBrush" Color="{StaticResource AccentSalmon}"/>
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource Hairline}"/>
    <SolidColorBrush x:Key="HairlineSoftBrush" Color="{StaticResource HairlineSoft}"/>
</ResourceDictionary>